{
  "name": "mnemosyne-extension",
  "displayName": "Mnemosyne Memory",
  "version": "1.0.0",
  "description": "Local-first persistent memory for AI conversations",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "build:chrome": "plasmo build --target=chrome-mv3",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "plasmo": "0.88.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "4.5.5",
    "cytoscape": "3.30.2",
    "cytoscape-cola": "2.5.1"
  },
  "devDependencies": {
    "@types/chrome": "0.0.270",
    "@types/cytoscape": "3.21.8",
    "@types/node": "20.14.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  },
  "manifest": {
    "name": "Mnemosyne Memory",
    "permissions": ["storage", "activeTab", "scripting", "sidePanel", "notifications", "clipboardWrite", "contextMenus", "alarms"],
    "host_permissions": [
      "https://claude.ai/*",
      "https://chat.openai.com/*",
      "https://chatgpt.com/*",
      "https://gemini.google.com/*",
      "https://localhost:7432/*",
      "http://localhost:7432/*"
    ],
    "commands": {
      "_execute_action": {
        "suggested_key": { "default": "Alt+W" },
        "description": "Open Mnemosyne (workspace switcher & controls)"
      },
      "toggle-sidebar": {
        "suggested_key": { "default": "Alt+M" },
        "description": "Toggle the Mnemosyne sidebar"
      },
      "toggle-capture": {
        "suggested_key": { "default": "Alt+P" },
        "description": "Pause / resume capture"
      },
      "toggle-incognito": {
        "suggested_key": { "default": "Alt+I" },
        "description": "Toggle incognito mode"
      }
    }
  }
}
