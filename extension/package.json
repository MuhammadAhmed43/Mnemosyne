{
  "name": "mnemosyne-extension",
  "displayName": "Mnemosyne Memory",
  "version": "1.0.0",
  "description": "Local-first persistent memory for AI conversations",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "build:chrome": "plasmo build --target=chrome-mv3",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "cytoscape": "3.30.2",
    "cytoscape-cola": "2.5.1",
    "material-symbols": "^0.27.2",
    "plasmo": "0.88.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-force-graph-3d": "^1.29.1",
    "three": "^0.184.0",
    "three-spritetext": "^1.10.0",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/chrome": "0.0.270",
    "@types/cytoscape": "3.21.8",
    "@types/node": "20.14.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  },
  "manifest": {
    "name": "Mnemosyne Memory",
    "permissions": [
      "storage",
      "activeTab",
      "scripting",
      "sidePanel",
      "notifications",
      "clipboardWrite",
      "contextMenus",
      "alarms"
    ],
    "host_permissions": [
      "https://claude.ai/*",
      "https://chat.openai.com/*",
      "https://chatgpt.com/*",
      "https://gemini.google.com/*",
      "https://localhost:7432/*",
      "http://localhost:7432/*"
    ],
    "commands": {
      "_execute_action": {
        "suggested_key": {
          "default": "Alt+W"
        },
        "description": "Open Mnemosyne (workspace switcher & controls)"
      },
      "toggle-sidebar": {
        "suggested_key": {
          "default": "Alt+M"
        },
        "description": "Toggle the Mnemosyne sidebar"
      },
      "toggle-capture": {
        "suggested_key": {
          "default": "Alt+P"
        },
        "description": "Pause / resume capture"
      },
      "toggle-incognito": {
        "suggested_key": {
          "default": "Alt+I"
        },
        "description": "Toggle incognito mode"
      }
    }
  }
}
